#!/usr/bin/env bash

set -euo pipefail

AUTHOR="@me"
MODE="failed"
BASE_BRANCH="main"
DRY_RUN=false

usage() {
  cat <<EOF
Usage:
  gh sync-prs [options]

Options:
  --author <author>      PR author to filter by. Default: @me
  --all                  Sync all open PRs from author
  --failed               Sync only open PRs with failing CI. Default
  --base <branch>        Base branch to merge. Default: main
  --dry-run              Show what would be updated, without changing anything
  -h, --help             Show help

Examples:
  gh sync-prs
  gh sync-prs --dry-run
  gh sync-prs --all
  gh sync-prs --author rodrigosf672
  gh sync-prs --base main --failed
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --author)
      AUTHOR="$2"
      shift 2
      ;;
    --all)
      MODE="all"
      shift
      ;;
    --failed)
      MODE="failed"
      shift
      ;;
    --base)
      BASE_BRANCH="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1"
      echo ""
      usage
      exit 1
      ;;
  esac
done

if ! command -v gh >/dev/null 2>&1; then
  echo "Error: gh is required but not installed."
  exit 1
fi

if ! command -v git >/dev/null 2>&1; then
  echo "Error: git is required but not installed."
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: run this from inside a git repository."
  exit 1
fi

git fetch origin

echo "Finding open PRs..."
echo "Author: $AUTHOR"
echo "Mode: $MODE"
echo "Base: origin/$BASE_BRANCH"

if [[ "$MODE" == "failed" ]]; then
  PR_QUERY='
    .[]
    | select(
        [.statusCheckRollup[]?.conclusion]
        | any(. == "FAILURE")
      )
    | "\(.number)|\(.headRefName)|\(.title)"
  '
else
  PR_QUERY='
    .[]
    | "\(.number)|\(.headRefName)|\(.title)"
  '
fi

UPDATED=0
FAILED=0
SKIPPED=0

# Note: the loop reads from a process substitution rather than a pipe so it
# runs in the current shell. Piping into `while` would run the loop body in a
# subshell, and the UPDATED/FAILED/SKIPPED counters would not survive the loop.
while IFS='|' read -r pr_number branch title; do
  [[ -z "$branch" ]] && continue

  echo ""
  echo "=== PR #$pr_number: $branch ==="
  echo "$title"

  worktree_path="$(
    git worktree list --porcelain |
      awk -v branch="refs/heads/$branch" '
        $1 == "worktree" { path = $2 }
        $1 == "branch" && $2 == branch { print path }
      '
  )"

  if [[ -n "$worktree_path" ]]; then
    repo_path="$worktree_path"
    echo "Worktree: $repo_path"
  else
    active_branch="$(git branch --show-current)"
    if [[ "$active_branch" != "$branch" ]]; then
      echo "No worktree found for '$branch' (on '$active_branch'); skipping."
      SKIPPED=$((SKIPPED + 1))
      continue
    fi
    repo_path="$(pwd)"
    echo "No worktree found; using current repo."
  fi

  if [[ "$DRY_RUN" == true ]]; then
    echo "Would sync:"
    echo "  cd $repo_path"
    echo "  git fetch origin"
    echo "  git checkout $branch"
    echo "  git merge origin/$branch"
    echo "  git merge origin/$BASE_BRANCH"
    echo "  git push"
    SKIPPED=$((SKIPPED + 1))
    continue
  fi

  # The steps are chained with && rather than relying on `set -e`: a subshell
  # used as an `if` condition runs with `set -e` disabled, so a failing merge
  # would otherwise fall through to `git push` and be reported as success. The
  # && chain makes the subshell's exit status reflect the first failing step,
  # so a merge conflict is correctly counted as a failure and skipped.
  if (
    cd "$repo_path" &&
      git fetch origin &&
      { [[ "$(git branch --show-current)" == "$branch" ]] || git checkout "$branch"; } &&
      { echo "Merging latest remote PR branch..." && git merge "origin/$branch"; } &&
      { echo "Merging origin/$BASE_BRANCH..." && git merge "origin/$BASE_BRANCH"; } &&
      { echo "Pushing..." && git push; }
  ); then
    UPDATED=$((UPDATED + 1))
  else
    FAILED=$((FAILED + 1))
    echo ""
    echo "Failed to update $branch."
    echo "You may need to resolve conflicts manually in:"
    echo "$repo_path"
    echo "Continuing with the next PR..."
  fi
done < <(
  gh pr list \
    --author "$AUTHOR" \
    --state open \
    --json number,title,headRefName,statusCheckRollup \
    --jq "$PR_QUERY"
)

echo ""
echo "Done."
echo "Updated: $UPDATED"
echo "Failed: $FAILED"
echo "Skipped: $SKIPPED"
